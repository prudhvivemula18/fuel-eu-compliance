{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "prisma generate && tsx watch src/infrastructure/server/main.ts",
    "start": "node dist/infrastructure/server/main.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma generate && tsx src/infrastructure/db/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx src/infrastructure/db/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.16.5",
    "dotenv": "^16.6.1",
    "prisma": "^6.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
